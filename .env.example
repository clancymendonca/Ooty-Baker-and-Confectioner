# Copy to `.env.local` and fill in (never commit secrets).
# See README.md for Supabase pooler URL format.

DATABASE_URL=

AUTH_SESSION_SECRET=
NEXT_PUBLIC_SITE_URL=
NEXTAUTH_URL=

# Vercel Blob (recommended on Vercel). Token from: Dashboard → Storage → Blob → Settings
BLOB_READ_WRITE_TOKEN=

# Or Supabase Storage instead of / in addition to Blob
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=
